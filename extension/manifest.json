{
  "manifest_version": 3,
  "name": "Distillery",
  "version": "1.0.0",
  "description": "Send articles directly to Distillery for reading",
  "permissions": [
    "contextMenus",
    "notifications",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
