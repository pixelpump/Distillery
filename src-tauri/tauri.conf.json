{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Distillery",
  "version": "1.0.0",
  "identifier": "com.distillery.app",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Distillery",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/distillery-server"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
